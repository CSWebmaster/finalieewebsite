rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      // Fetch role based on AUTH UID from the users collection
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isLoggedIn() && getUserRole() == "admin";
    }

    function isWriter() {
      return isLoggedIn() && getUserRole() == "writer";
    }

    // AWARDS COLLECTION
    match /awards/{doc} {
      allow read: if true;
      allow write: if isAdmin() || isWriter();
    }

    // EVENTS COLLECTION
    match /events/{doc} {
      allow read: if true;
      allow write: if isAdmin() || isWriter();
    }

    // MEMBERS COLLECTION
    match /members/{doc} {
      allow read: if true;
      allow write: if isAdmin() || isWriter();
    }

    // JOURNEY COLLECTION
    match /journey/{doc} {
      allow read: if true;
      allow write: if isAdmin() || isWriter();
    }

    // BLOGS COLLECTION
    match /blogs/{doc} {
      allow read: if true;
      allow write: if isAdmin() || isWriter();
    }

    // USERS (RBAC) COLLECTION - Admins only
    match /users/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ADMIN ACTIVITY LOGS - Admins only
    match /adminActivityLogs/{doc} {
      allow read: if isAdmin();
      allow write: if isLoggedIn(); 
    }
  }
}